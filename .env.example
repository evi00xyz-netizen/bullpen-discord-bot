# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
TRADE_CHANNEL_ID=your_channel_id_here

# Bullpen CLI Configuration
# Full path to bullpen binary (run `which bullpen` to find it)
BULLPEN_BIN=bullpen
# Bullpen home directory (usually ~/.bullpen)
BULLPEN_HOME=/home/youruser/.bullpen
# Bullpen environment
BULLPEN_ENV=production
# Set to true if running the bot on Windows but bullpen is installed in WSL2
BULLPEN_USE_WSL=false

# Default buy amount when using natural language commands
# e.g. "Buy "Rinderknech" on Polymarket: https://..." will buy $2
DEFAULT_BUY_AMOUNT=2
