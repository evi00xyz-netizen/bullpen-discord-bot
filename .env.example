# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Channel ID where the bot listens for trade commands
TRADE_CHANNEL_ID=your_channel_id_here

# Bullpen CLI binary path (default: bullpen)
BULLPEN_BIN=bullpen

# Bullpen home directory (where login session is stored)
# On Linux/Mac: /home/youruser/.bullpen or /root/.bullpen
# On Windows: C:\Users\youruser\.bullpen
BULLPEN_HOME=/root/.bullpen

# Bullpen environment
BULLPEN_ENV=production
